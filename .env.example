# ---------------------------------------------------------------------------
# Musemint environment — every var is OPTIONAL. With an empty file the app runs
# as an open, single-user demo on local SQLite using the deterministic mock AI
# provider. Copy to `.env` and fill in only what you need.
# ---------------------------------------------------------------------------

# Database. Defaults to local SQLite; set a postgres:// URL for Neon/Supabase.
DATABASE_URL="file:./dev.db"

# --- AI providers — picked in this order, first non-empty wins. Mock if all blank.
GOOGLE_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
MISTRAL_API_KEY=""

# Optional enrichment — set a SEPARATE key from GOOGLE_API_KEY,
# restricted to YouTube Data API v3 only.
YOUTUBE_API_KEY=""

# --- Auth (opt-in single-password gate) ---
# Gate the whole instance behind one password. If blank, the app is an OPEN demo
# (anyone with the URL can read/write, and the destructive data-wipe is disabled).
# When set, visitors enter it once and it's stored in an httpOnly cookie.
APP_PASSWORD=""
# Optional server-side secret mixed into the auth token. Rotating it invalidates
# every issued login cookie at once, so a leaked cookie isn't a permanent key.
AUTH_SECRET=""

# --- Security knobs (all optional; safe defaults if blank) ---
# Max paid AI calls counted per day (AiProcessingLog rows). Default 200.
# (RECALLOS_DAILY_AI_BUDGET is still read as a fallback for older deploys.)
MUSEMINT_DAILY_AI_BUDGET="200"
# Bearer token required for MCP write tools (capture, build-pack).
# If blank, MCP write tools are disabled (read tools still work).
MCP_SECRET=""

# --- Daily digest cron (machine-to-machine) ---
# Bearer secret the scheduled /api/notifications/run job must present.
# Vercel Cron sends CRON_SECRET automatically; NOTIFY_SECRET is the manual name.
NOTIFY_SECRET=""
# Absolute base URL the cron job calls back into. On Vercel, VERCEL_URL is used
# automatically; set this for non-Vercel hosts. e.g. https://your-app.com
NEXT_PUBLIC_APP_URL=""

# --- Web Push notifications (dormant until set) ---
# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# --- Email digest via Resend (dormant until set) ---
RESEND_API_KEY=""
NOTIFY_EMAIL_TO=""
NOTIFY_EMAIL_FROM="Musemint <notifications@yourdomain.com>"
