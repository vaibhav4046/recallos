DATABASE_URL="file:./dev.db"

# AI providers — picked in this order, first non-empty wins. Mock if all blank.
GOOGLE_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROQ_API_KEY=""
MISTRAL_API_KEY=""

# Optional enrichment — set a SEPARATE key from GOOGLE_API_KEY,
# restricted to YouTube Data API v3 only.
YOUTUBE_API_KEY=""

# Auth (NextAuth placeholders — local single-user mode if blank)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# --- Security knobs (all optional; safe defaults if blank) ---
# Max paid AI calls counted per day (AiProcessingLog rows). Default 200.
# (RECALLOS_DAILY_AI_BUDGET is still read as a fallback for older deploys.)
MUSEMINT_DAILY_AI_BUDGET="200"
# Bearer token required for MCP write tools (capture, build-pack).
# If blank, MCP write tools are disabled (read tools still work).
MCP_SECRET=""
# Gate the whole app behind a password. If blank, the app is an open demo.
# When set, visitors must enter it once; it's stored in an httpOnly cookie.
APP_PASSWORD=""
